#!/usr/bin/env bash

set -uo pipefail
shopt -s nullglob

SCRIPT_NAME="ytb"
OUTPUT_ROOT="${YTB_OUTPUT_ROOT:-${HOME}/Videos}"
COOKIE_BROWSER="${YTB_COOKIES_BROWSER:-chrome}"
VIDEO_ENCODER_MODE="${YTB_VIDEO_ENCODER:-auto}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

CURRENT_LOG_FILE=""
LAST_VIDEO_STATUS="failed"
COOKIE_BROWSER_AVAILABLE=0
YTDLP_BIN=""
SELECTED_VIDEO_ENCODER="libx264"

usage() {
  cat <<'EOF'
Usage: ytb <youtube-url>

Downloads a YouTube video or playlist into ~/Videos by default.
- Each video gets its own directory.
- Manual English subtitles are burned into a final video when available.
- Auto-generated subtitles are never used.
- Age-restricted videos retry with browser cookies only when needed.

Optional environment variables:
- YTB_OUTPUT_ROOT=/path/to/output
- YTB_COOKIES_BROWSER=chrome|firefox|chromium|none
- YTB_VIDEO_ENCODER=auto|cpu|libx264|h264_nvenc|hevc_nvenc|av1_nvenc
EOF
}

log() {
  local message="$1"
  printf '[%s] %s\n' "$SCRIPT_NAME" "$message" >&2
  if [[ -n "${CURRENT_LOG_FILE:-}" ]]; then
    printf '[%s] %s\n' "$SCRIPT_NAME" "$message" >>"$CURRENT_LOG_FILE"
  fi
}

warn() {
  log "WARNING: $1"
}

die() {
  log "ERROR: $1"
  exit 1
}

run_logged() {
  local log_file="${CURRENT_LOG_FILE:-}"
  if [[ -n "$log_file" ]]; then
    "$@" 2>&1 | tee -a "$log_file"
    return "${PIPESTATUS[0]}"
  fi
  "$@"
}

sanitize_name() {
  local input="$1"
  local sanitized

  sanitized="$(printf '%s' "$input" \
    | tr '\r\n\t' '   ' \
    | sed -E "s/[^[:alnum:] ._()-]+/-/g; s/[[:space:]]+/ /g; s/^[[:space:].-]+//; s/[[:space:].-]+$//; s/-{2,}/-/g" \
    | cut -c1-180)"

  if [[ -z "$sanitized" ]]; then
    sanitized="untitled"
  fi

  printf '%s' "$sanitized"
}

get_url_host() {
  local url="$1"
  local without_scheme="${url#*://}"
  printf '%s' "${without_scheme%%/*}"
}

is_supported_youtube_url() {
  local url="$1"
  local host

  [[ "$url" == http://* || "$url" == https://* ]] || return 1
  host="$(get_url_host "$url")"

  case "$host" in
    youtube.com|www.youtube.com|m.youtube.com|youtu.be)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ensure_base_dependencies() {
  local missing=()
  local dep

  for dep in jq ffmpeg ffprobe; do
    if ! command -v "$dep" >/dev/null 2>&1; then
      missing+=("$dep")
    fi
  done

  if ((${#missing[@]} == 0)); then
    return 0
  fi

  die "Missing required tools: ${missing[*]}. Re-run ./install.sh to install them."
}

ensure_ytdlp() {
  local candidate=""
  local version=""

  if [[ -x "${SCRIPT_DIR}/yt-dlp" ]]; then
    candidate="${SCRIPT_DIR}/yt-dlp"
  else
    candidate="$(command -v yt-dlp 2>/dev/null || true)"
  fi

  if [[ -z "$candidate" || ! -x "$candidate" ]]; then
    die "yt-dlp is not installed. Re-run ./install.sh."
  fi

  YTDLP_BIN="$candidate"
  version="$("$YTDLP_BIN" --version 2>/dev/null | head -n 1 || true)"
  [[ -n "$version" ]] || die "yt-dlp exists but could not be executed: ${YTDLP_BIN}"
  log "Using yt-dlp ${version} from ${YTDLP_BIN}"
}

browser_profile_exists() {
  local browser="$1"

  case "$browser" in
    none)
      return 1
      ;;
    chrome)
      [[ -d "${HOME}/.config/google-chrome" \
        || -d "${HOME}/.config/google-chrome-beta" \
        || -d "${HOME}/.config/google-chrome-unstable" ]]
      ;;
    firefox)
      [[ -d "${HOME}/.mozilla/firefox" ]]
      ;;
    chromium)
      [[ -d "${HOME}/.config/chromium" ]]
      ;;
    *)
      return 0
      ;;
  esac
}

init_cookie_support() {
  if [[ "$COOKIE_BROWSER" == "none" ]]; then
    COOKIE_BROWSER_AVAILABLE=0
    log "Browser cookies disabled via YTB_COOKIES_BROWSER=none"
    return 0
  fi

  if browser_profile_exists "$COOKIE_BROWSER"; then
    COOKIE_BROWSER_AVAILABLE=1
    log "Will retry age-restricted videos with browser cookies from ${COOKIE_BROWSER}"
    return 0
  fi

  COOKIE_BROWSER_AVAILABLE=0
  warn "No usable ${COOKIE_BROWSER} browser profile was found. Public videos can still work, but age-restricted videos may fail."
}

ffmpeg_has_encoder() {
  local encoder="$1"
  grep -Eq "[[:space:]]${encoder}[[:space:]]" < <(ffmpeg -hide_banner -encoders 2>/dev/null)
}

stream_packet_bytes() {
  local media_path="$1"
  local stream_selector="$2"

  ffprobe \
    -v error \
    -select_streams "$stream_selector" \
    -show_entries packet=size \
    -of csv=p=0 \
    "$media_path" 2>/dev/null | awk 'NF { sum += $1 } END { printf "%.0f", sum + 0 }'
}

bitrate_from_bytes_and_duration() {
  local total_bytes="$1"
  local duration_seconds="$2"

  awk -v bytes="$total_bytes" -v duration="$duration_seconds" '
    BEGIN {
      if (bytes <= 0 || duration <= 0) {
        print 0
      } else {
        printf "%.0f", (bytes * 8) / duration
      }
    }
  '
}

normalize_extension() {
  local path="$1"
  local ext="${path##*.}"
  printf '%s' "${ext,,}"
}

init_video_encoder() {
  case "$VIDEO_ENCODER_MODE" in
    auto)
      if command -v nvidia-smi >/dev/null 2>&1 && { ffmpeg_has_encoder av1_nvenc || ffmpeg_has_encoder h264_nvenc || ffmpeg_has_encoder hevc_nvenc; }; then
        SELECTED_VIDEO_ENCODER="gpu-auto"
        log "Using source-matched video encoding with NVIDIA GPU when supported"
      else
        SELECTED_VIDEO_ENCODER="libx264"
        log "Using CPU video encoding via libx264"
      fi
      ;;
    cpu|libx264)
      SELECTED_VIDEO_ENCODER="libx264"
      log "Using CPU video encoding via libx264"
      ;;
    h264_nvenc|hevc_nvenc|av1_nvenc)
      if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder "$VIDEO_ENCODER_MODE"; then
        SELECTED_VIDEO_ENCODER="$VIDEO_ENCODER_MODE"
        log "Using NVIDIA GPU video encoding via ${SELECTED_VIDEO_ENCODER}"
      else
        warn "Requested ${VIDEO_ENCODER_MODE}, but it is not available. Falling back to CPU libx264."
        SELECTED_VIDEO_ENCODER="libx264"
      fi
      ;;
    *)
      warn "Unknown YTB_VIDEO_ENCODER=${VIDEO_ENCODER_MODE}. Falling back to auto detection."
      if command -v nvidia-smi >/dev/null 2>&1 && { ffmpeg_has_encoder av1_nvenc || ffmpeg_has_encoder h264_nvenc || ffmpeg_has_encoder hevc_nvenc; }; then
        SELECTED_VIDEO_ENCODER="gpu-auto"
        log "Using source-matched video encoding with NVIDIA GPU when supported"
      else
        SELECTED_VIDEO_ENCODER="libx264"
        log "Using CPU video encoding via libx264"
      fi
      ;;
  esac
}

select_source_matched_encoder() {
  local source_codec="$1"

  case "$VIDEO_ENCODER_MODE" in
    auto)
      case "$source_codec" in
        av1)
          if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder av1_nvenc; then
            printf 'av1_nvenc'
            return 0
          fi
          ;;
        h264)
          if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder h264_nvenc; then
            printf 'h264_nvenc'
            return 0
          fi
          printf 'libx264'
          return 0
          ;;
        hevc)
          if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder hevc_nvenc; then
            printf 'hevc_nvenc'
            return 0
          fi
          ;;
        vp9)
          if ffmpeg_has_encoder libvpx-vp9; then
            printf 'libvpx-vp9'
            return 0
          fi
          ;;
      esac
      if [[ "$SELECTED_VIDEO_ENCODER" == "gpu-auto" ]]; then
        printf 'libx264'
      else
        printf '%s' "$SELECTED_VIDEO_ENCODER"
      fi
      ;;
    cpu|libx264)
      printf 'libx264'
      ;;
    *)
      printf '%s' "$SELECTED_VIDEO_ENCODER"
      ;;
  esac
}

burned_output_extension() {
  local media_path="$1"
  local ext

  ext="$(normalize_extension "$media_path")"
  case "$ext" in
    webm)
      printf 'webm'
      ;;
    mp4|m4v|mov)
      printf 'mp4'
      ;;
    *)
      printf '%s' "$ext"
      ;;
  esac
}

is_age_gate_error() {
  local error_file="$1"
  grep -Eiq 'Sign in to confirm your age|Please sign in|This video may be inappropriate for some users|age-restricted' "$error_file"
}

is_cookie_decryption_error() {
  local error_file="$1"
  grep -Eiq 'cannot decrypt|could not decrypt|could not be decrypted|Extracted 0 cookies|no key found' "$error_file"
}

yt_dlp_capture_json() {
  local output_json="$1"
  local error_file="$2"
  local cookie_mode_var="$3"
  shift 3
  local -a args=("$@")

  if "$YTDLP_BIN" "${args[@]}" >"$output_json" 2>"$error_file"; then
    printf -v "$cookie_mode_var" '%s' "0"
    return 0
  fi

  if ((COOKIE_BROWSER_AVAILABLE)) && is_age_gate_error "$error_file"; then
    log "Retrying with ${COOKIE_BROWSER} cookies"
    if "$YTDLP_BIN" --cookies-from-browser "$COOKIE_BROWSER" "${args[@]}" >"$output_json" 2>"$error_file"; then
      printf -v "$cookie_mode_var" '%s' "1"
      return 0
    fi
  fi

  printf -v "$cookie_mode_var" '%s' "0"
  return 1
}

choose_manual_english_subtitle() {
  local metadata_json="$1"

  jq -r '
    (.subtitles // {}) as $subs
    | if ($subs | has("en")) then
        "en"
      elif ($subs | has("en-US")) then
        "en-US"
      elif ($subs | has("en-GB")) then
        "en-GB"
      else
        ($subs | keys_unsorted[]? | select(test("^en-")))
      end
  ' "$metadata_json" | head -n 1
}

is_playlist_json() {
  local metadata_json="$1"

  jq -e '
    (._type // "") == "playlist"
    or ((.entries // null) != null and (.entries | type) == "array")
  ' "$metadata_json" >/dev/null 2>&1
}

build_watch_url() {
  local value="$1"
  printf 'https://www.youtube.com/watch?v=%s' "$value"
}

write_error_log() {
  local error_file="$1"
  if [[ -n "${CURRENT_LOG_FILE:-}" && -f "$error_file" ]]; then
    cat "$error_file" >>"$CURRENT_LOG_FILE"
  fi
}

fetch_top_level_json() {
  local url="$1"
  local output_json="$2"
  local error_file="$3"
  local cookie_mode_var="$4"

  yt_dlp_capture_json "$output_json" "$error_file" "$cookie_mode_var" \
    --dump-single-json \
    --flat-playlist \
    "$url"
}

fetch_video_metadata() {
  local url="$1"
  local output_json="$2"
  local error_file="$3"
  local cookie_mode_var="$4"

  yt_dlp_capture_json "$output_json" "$error_file" "$cookie_mode_var" \
    --dump-single-json \
    "$url"
}

download_media() {
  local url="$1"
  local outtmpl="$2"
  local path_file="$3"
  local use_cookies="$4"
  local -a cookie_args=()

  if [[ "$use_cookies" == "1" ]]; then
    cookie_args=(--cookies-from-browser "$COOKIE_BROWSER")
  fi

  : >"$path_file"
  run_logged "$YTDLP_BIN" \
    "${cookie_args[@]}" \
    --print-to-file after_move:filepath "$path_file" \
    --format "bv*+ba/b" \
    --output "$outtmpl" \
    "$url"
}

download_manual_subtitles() {
  local url="$1"
  local outtmpl="$2"
  local subtitle_lang="$3"
  local use_cookies="$4"
  local -a cookie_args=()

  if [[ "$use_cookies" == "1" ]]; then
    cookie_args=(--cookies-from-browser "$COOKIE_BROWSER")
  fi

  run_logged "$YTDLP_BIN" \
    "${cookie_args[@]}" \
    --skip-download \
    --write-subs \
    --sub-langs "$subtitle_lang" \
    --convert-subs srt \
    --output "$outtmpl" \
    "$url"
}

burn_subtitles() {
  local media_path="$1"
  local subtitle_path="$2"
  local output_path="$3"
  local workdir media_name output_name temp_subtitle temp_subtitle_name
  local probe_json
  local source_duration source_video_codec source_audio_codec source_pix_fmt
  local source_color_range source_color_space source_color_transfer source_color_primaries
  local source_video_bitrate source_audio_bitrate source_video_bytes source_audio_bytes
  local output_extension encoder status
  local -a video_args audio_args color_args container_args fallback_video_args fallback_pix_fmt_args

  workdir="$(dirname "$subtitle_path")"
  media_name="$(basename "$media_path")"
  output_name="$(basename "$output_path")"
  temp_subtitle_name=".ytb-burn-input.srt"
  temp_subtitle="${workdir}/${temp_subtitle_name}"
  output_extension="$(normalize_extension "$output_path")"

  probe_json="$(ffprobe \
    -v error \
    -show_entries stream=index,codec_name,codec_type,bit_rate,avg_frame_rate,pix_fmt,color_range,color_space,color_transfer,color_primaries,sample_rate,channels,channel_layout:format=duration \
    -of json \
    "$media_path" 2>/dev/null)" || return 1

  source_duration="$(jq -r '.format.duration // "0"' <<<"$probe_json")"
  source_video_codec="$(jq -r '.streams[] | select(.codec_type == "video") | .codec_name // empty' <<<"$probe_json" | head -n 1)"
  source_audio_codec="$(jq -r '.streams[] | select(.codec_type == "audio") | .codec_name // empty' <<<"$probe_json" | head -n 1)"
  source_pix_fmt="$(jq -r '.streams[] | select(.codec_type == "video") | .pix_fmt // empty' <<<"$probe_json" | head -n 1)"
  source_color_range="$(jq -r '.streams[] | select(.codec_type == "video") | .color_range // empty' <<<"$probe_json" | head -n 1)"
  source_color_space="$(jq -r '.streams[] | select(.codec_type == "video") | .color_space // empty' <<<"$probe_json" | head -n 1)"
  source_color_transfer="$(jq -r '.streams[] | select(.codec_type == "video") | .color_transfer // empty' <<<"$probe_json" | head -n 1)"
  source_color_primaries="$(jq -r '.streams[] | select(.codec_type == "video") | .color_primaries // empty' <<<"$probe_json" | head -n 1)"
  source_video_bitrate="$(jq -r '.streams[] | select(.codec_type == "video") | .bit_rate // empty' <<<"$probe_json" | head -n 1)"
  source_audio_bitrate="$(jq -r '.streams[] | select(.codec_type == "audio") | .bit_rate // empty' <<<"$probe_json" | head -n 1)"

  if [[ -z "$source_video_bitrate" || ! "$source_video_bitrate" =~ ^[0-9]+$ || "$source_video_bitrate" -le 0 ]]; then
    source_video_bytes="$(stream_packet_bytes "$media_path" "v:0")"
    source_video_bitrate="$(bitrate_from_bytes_and_duration "$source_video_bytes" "$source_duration")"
  fi

  if [[ -z "$source_audio_bitrate" || ! "$source_audio_bitrate" =~ ^[0-9]+$ || "$source_audio_bitrate" -le 0 ]]; then
    source_audio_bytes="$(stream_packet_bytes "$media_path" "a:0")"
    source_audio_bitrate="$(bitrate_from_bytes_and_duration "$source_audio_bytes" "$source_duration")"
  fi

  [[ "$source_video_bitrate" =~ ^[0-9]+$ ]] || source_video_bitrate=0
  [[ "$source_audio_bitrate" =~ ^[0-9]+$ ]] || source_audio_bitrate=0

  encoder="$(select_source_matched_encoder "$source_video_codec")"
  color_args=()
  container_args=()

  [[ -n "$source_color_range" ]] && color_args+=(-color_range "$source_color_range")
  [[ -n "$source_color_space" ]] && color_args+=(-colorspace "$source_color_space")
  [[ -n "$source_color_transfer" ]] && color_args+=(-color_trc "$source_color_transfer")
  [[ -n "$source_color_primaries" ]] && color_args+=(-color_primaries "$source_color_primaries")

  case "$output_extension" in
    webm)
      case "$encoder" in
        av1_nvenc)
          video_args=(
            -fps_mode passthrough
            -c:v av1_nvenc
            -preset p5
            -tune hq
            -rc vbr
            -b:v "$source_video_bitrate"
            -maxrate "$source_video_bitrate"
            -bufsize "$((source_video_bitrate * 2))"
            -rc-lookahead 20
            -spatial-aq 1
            -temporal-aq 1
          )
          ;;
        libvpx-vp9)
          video_args=(
            -fps_mode passthrough
            -c:v libvpx-vp9
            -deadline good
            -cpu-used 3
            -row-mt 1
            -tile-columns 2
            -frame-parallel 1
            -b:v "$source_video_bitrate"
            -minrate "$source_video_bitrate"
            -maxrate "$source_video_bitrate"
          )
          ;;
        *)
          if ffmpeg_has_encoder libvpx-vp9; then
            warn "Could not preserve source codec ${source_video_codec} for WebM. Falling back to VP9 bitrate-matched encoding."
            video_args=(
              -fps_mode passthrough
              -c:v libvpx-vp9
              -deadline good
              -cpu-used 3
              -row-mt 1
              -tile-columns 2
              -frame-parallel 1
              -b:v "$source_video_bitrate"
              -minrate "$source_video_bitrate"
              -maxrate "$source_video_bitrate"
            )
          elif command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder av1_nvenc; then
            warn "Could not preserve source codec ${source_video_codec} for WebM. Falling back to AV1 NVENC bitrate-matched encoding."
            video_args=(
              -fps_mode passthrough
              -c:v av1_nvenc
              -preset p5
              -tune hq
              -rc vbr
              -b:v "$source_video_bitrate"
              -maxrate "$source_video_bitrate"
              -bufsize "$((source_video_bitrate * 2))"
              -rc-lookahead 20
              -spatial-aq 1
              -temporal-aq 1
            )
          else
            warn "Could not preserve source codec ${source_video_codec} for WebM, and no usable WebM encoder is available on this machine."
            return 1
          fi
          ;;
      esac

      if [[ "$source_audio_codec" == "opus" || "$source_audio_codec" == "vorbis" ]]; then
        audio_args=(-c:a copy)
      else
        audio_args=(-c:a libopus -b:a "$source_audio_bitrate")
      fi
      ;;
    *)
      case "$encoder" in
        h264_nvenc)
          video_args=(
            -fps_mode passthrough
            -c:v h264_nvenc
            -preset p5
            -tune hq
            -rc vbr
            -b:v "$source_video_bitrate"
            -maxrate "$source_video_bitrate"
            -bufsize "$((source_video_bitrate * 2))"
            -rc-lookahead 20
            -spatial-aq 1
            -temporal-aq 1
          )
          ;;
        hevc_nvenc)
          video_args=(
            -fps_mode passthrough
            -c:v hevc_nvenc
            -preset p5
            -tune hq
            -rc vbr
            -b:v "$source_video_bitrate"
            -maxrate "$source_video_bitrate"
            -bufsize "$((source_video_bitrate * 2))"
            -rc-lookahead 20
            -spatial-aq 1
            -temporal-aq 1
          )
          ;;
        *)
          video_args=(
            -fps_mode passthrough
            -c:v libx264
            -preset medium
            -b:v "$source_video_bitrate"
            -maxrate "$source_video_bitrate"
            -bufsize "$((source_video_bitrate * 2))"
          )
          ;;
      esac

      if [[ "$source_audio_codec" == "aac" || "$source_audio_codec" == "mp3" ]]; then
        audio_args=(-c:a copy)
      else
        audio_args=(-c:a aac -b:a "$source_audio_bitrate")
      fi
      container_args=(-movflags +faststart)
      ;;
  esac

  [[ -n "$source_pix_fmt" ]] && video_args+=(-pix_fmt "$source_pix_fmt")

  cp "$subtitle_path" "$temp_subtitle" || return 1

  (
    cd "$workdir" || exit 1

    run_logged ffmpeg \
      -y \
      -i "$media_name" \
      -vf "subtitles=${temp_subtitle_name}" \
      -map "0:v:0" \
      -map "0:a?" \
      "${video_args[@]}" \
      "${color_args[@]}" \
      "${audio_args[@]}" \
      "${container_args[@]}" \
      -sn \
      "$output_name"
  )
  status=$?

  if [[ "$status" -ne 0 && "$output_extension" == "mp4" && "$encoder" != "libx264" ]]; then
    warn "GPU encode with ${encoder} failed. Retrying with CPU libx264 while preserving source bitrate."
    rm -f "$temp_subtitle"
    cp "$subtitle_path" "$temp_subtitle" || return 1
    fallback_video_args=(
      -fps_mode passthrough
      -c:v libx264
      -preset medium
      -b:v "$source_video_bitrate"
      -maxrate "$source_video_bitrate"
      -bufsize "$((source_video_bitrate * 2))"
    )
    fallback_pix_fmt_args=()
    [[ -n "$source_pix_fmt" ]] && fallback_pix_fmt_args=(-pix_fmt "$source_pix_fmt")
    (
      cd "$workdir" || exit 1
      run_logged ffmpeg \
        -y \
        -i "$media_name" \
        -vf "subtitles=${temp_subtitle_name}" \
        -map "0:v:0" \
        -map "0:a?" \
        "${fallback_video_args[@]}" \
        "${fallback_pix_fmt_args[@]}" \
        "${color_args[@]}" \
        "${audio_args[@]}" \
        -movflags +faststart \
        -sn \
        "$output_name"
    )
    status=$?
  fi

  rm -f "$temp_subtitle"
  return "$status"
}

record_metadata_copy() {
  local source_json="$1"
  local target_path="$2"
  cp "$source_json" "$target_path"
}

process_video() {
  local video_url="$1"
  local parent_dir="$2"
  local fallback_title="${3:-Unknown Video}"
  local fallback_id="${4:-}"

  local metadata_json error_file used_cookies
  local raw_title safe_title video_id dir_name video_dir
  local base_name base_path subtitle_lang subtitle_path burned_path burned_ext
  local path_file media_path

  LAST_VIDEO_STATUS="failed"
  metadata_json="$(mktemp)"
  error_file="$(mktemp)"
  used_cookies="0"

  if ! fetch_video_metadata "$video_url" "$metadata_json" "$error_file" used_cookies; then
    safe_title="$(sanitize_name "$fallback_title")"
    if [[ -n "$fallback_id" ]]; then
      dir_name="${safe_title} [${fallback_id}]"
    else
      dir_name="$safe_title"
    fi
    video_dir="${parent_dir}/${dir_name}"
    mkdir -p "$video_dir"
    CURRENT_LOG_FILE="${video_dir}/ytb.log"
    : >"$CURRENT_LOG_FILE"
    write_error_log "$error_file"

    if is_age_gate_error "$error_file"; then
      if is_cookie_decryption_error "$error_file"; then
        warn "Failed to access ${video_url}. ${COOKIE_BROWSER} cookies could not be decrypted. Unlock your desktop keyring, re-open the browser, or try YTB_COOKIES_BROWSER=firefox."
      elif ((COOKIE_BROWSER_AVAILABLE)); then
        warn "Failed to access ${video_url}. A signed-in ${COOKIE_BROWSER} profile is required for this age-restricted video."
      else
        warn "Failed to access ${video_url}. Configure YTB_COOKIES_BROWSER for a signed-in browser profile to handle age-restricted videos."
      fi
    else
      warn "Failed to fetch metadata for ${video_url}"
    fi

    rm -f "$metadata_json" "$error_file"
    return 1
  fi

  raw_title="$(jq -r '.title // empty' "$metadata_json")"
  video_id="$(jq -r '.id // empty' "$metadata_json")"
  if [[ -z "$raw_title" ]]; then
    raw_title="$fallback_title"
  fi
  if [[ -z "$video_id" ]]; then
    video_id="$fallback_id"
  fi

  safe_title="$(sanitize_name "$raw_title")"
  if [[ -n "$video_id" ]]; then
    dir_name="${safe_title} [${video_id}]"
  else
    dir_name="$safe_title"
  fi

  video_dir="${parent_dir}/${dir_name}"
  mkdir -p "$video_dir"
  CURRENT_LOG_FILE="${video_dir}/ytb.log"
  : >"$CURRENT_LOG_FILE"

  record_metadata_copy "$metadata_json" "${video_dir}/metadata.json"
  log "Processing video: ${raw_title}"

  base_name="$dir_name"
  base_path="${video_dir}/${base_name}"
  path_file="$(mktemp)"

  if ! download_media "$video_url" "${base_path}.%(ext)s" "$path_file" "$used_cookies"; then
    warn "Media download failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  media_path="$(tail -n 1 "$path_file")"
  if [[ -z "$media_path" || ! -f "$media_path" ]]; then
    warn "Could not determine downloaded media path for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  subtitle_lang="$(choose_manual_english_subtitle "$metadata_json")"
  if [[ -z "$subtitle_lang" ]]; then
    warn "No manual English subtitles found for ${raw_title}; kept media without burned subtitles"
    LAST_VIDEO_STATUS="downloaded_no_subtitles"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 0
  fi

  if ! download_manual_subtitles "$video_url" "${base_path}.%(ext)s" "$subtitle_lang" "$used_cookies"; then
    warn "Subtitle download failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  subtitle_path="${base_path}.${subtitle_lang}.srt"
  if [[ ! -f "$subtitle_path" ]]; then
    local matches=( "${base_path}".en*.srt )
    if ((${#matches[@]} > 0)); then
      subtitle_path="${matches[0]}"
    fi
  fi

  if [[ ! -f "$subtitle_path" ]]; then
    warn "Subtitle file was not created for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  burned_ext="$(burned_output_extension "$media_path")"
  burned_path="${base_path} [burned].${burned_ext}"
  if ! burn_subtitles "$media_path" "$subtitle_path" "$burned_path"; then
    warn "Subtitle burn-in failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  log "Created burned video: ${burned_path}"
  LAST_VIDEO_STATUS="burned"
  rm -f "$metadata_json" "$error_file" "$path_file"
  return 0
}

process_playlist() {
  local top_level_json="$1"

  local playlist_title playlist_id safe_playlist_title playlist_dir
  local -a entry_payloads failed_items
  local processed=0 burned=0 without_subtitles=0 hard_failures=0
  local entry_payload entry_json fallback_id fallback_title entry_url

  playlist_title="$(jq -r '.title // .playlist_title // "Playlist"' "$top_level_json")"
  playlist_id="$(jq -r '.id // .playlist_id // empty' "$top_level_json")"
  safe_playlist_title="$(sanitize_name "$playlist_title")"

  if [[ -n "$playlist_id" ]]; then
    playlist_dir="${OUTPUT_ROOT}/${safe_playlist_title} [${playlist_id}]"
  else
    playlist_dir="${OUTPUT_ROOT}/${safe_playlist_title}"
  fi

  mkdir -p "$playlist_dir"
  record_metadata_copy "$top_level_json" "${playlist_dir}/metadata.json"
  CURRENT_LOG_FILE="${playlist_dir}/ytb.log"
  : >"$CURRENT_LOG_FILE"
  log "Processing playlist: ${playlist_title}"

  mapfile -t entry_payloads < <(jq -r '(.entries // [])[] | @base64' "$top_level_json")
  if ((${#entry_payloads[@]} == 0)); then
    die "Playlist metadata was fetched, but no entries were found"
  fi

  for entry_payload in "${entry_payloads[@]}"; do
    processed=$((processed + 1))
    entry_json="$(printf '%s' "$entry_payload" | base64 --decode)"
    fallback_id="$(jq -r '.id // empty' <<<"$entry_json")"
    fallback_title="$(jq -r '.title // "Unknown Video"' <<<"$entry_json")"
    entry_url="$(jq -r '.webpage_url // .url // empty' <<<"$entry_json")"

    if [[ -z "$entry_url" && -n "$fallback_id" ]]; then
      entry_url="$(build_watch_url "$fallback_id")"
    elif [[ -n "$entry_url" && "$entry_url" != http://* && "$entry_url" != https://* ]]; then
      entry_url="$(build_watch_url "$entry_url")"
    fi

    if [[ -z "$entry_url" ]]; then
      hard_failures=$((hard_failures + 1))
      failed_items+=("${fallback_title}${fallback_id:+ [${fallback_id}]}")
      warn "Skipping a playlist entry because no usable video URL was present"
      continue
    fi

    if process_video "$entry_url" "$playlist_dir" "$fallback_title" "$fallback_id"; then
      case "$LAST_VIDEO_STATUS" in
        burned)
          burned=$((burned + 1))
          ;;
        downloaded_no_subtitles)
          without_subtitles=$((without_subtitles + 1))
          ;;
      esac
    else
      hard_failures=$((hard_failures + 1))
      failed_items+=("${fallback_title}${fallback_id:+ [${fallback_id}]}")
    fi
  done

  CURRENT_LOG_FILE="${playlist_dir}/ytb.log"
  log "Playlist summary: total=${processed}, burned=${burned}, no-manual-en-subs=${without_subtitles}, hard-failures=${hard_failures}"

  if ((${#failed_items[@]} > 0)); then
    printf '[%s] Failed items:\n' "$SCRIPT_NAME" >&2
    for entry_payload in "${failed_items[@]}"; do
      printf '[%s] - %s\n' "$SCRIPT_NAME" "$entry_payload" >&2
      printf '[%s] - %s\n' "$SCRIPT_NAME" "$entry_payload" >>"$CURRENT_LOG_FILE"
    done
  fi

  if ((hard_failures > 0)); then
    return 1
  fi
  return 0
}

main() {
  local input_url top_level_json top_level_error top_level_used_cookies

  if [[ $# -ne 1 ]]; then
    usage >&2
    log "Tip: quote YouTube URLs that contain '&', for example: ytb \"https://www.youtube.com/watch?v=VIDEO_ID&t=30s\""
    exit 1
  fi

  input_url="$1"
  if ! is_supported_youtube_url "$input_url"; then
    die "Unsupported URL. Pass a YouTube watch, short, shorts, or playlist URL."
  fi

  ensure_base_dependencies
  ensure_ytdlp
  init_cookie_support
  init_video_encoder
  mkdir -p "$OUTPUT_ROOT"

  top_level_json="$(mktemp)"
  top_level_error="$(mktemp)"
  top_level_used_cookies="0"

  if ! fetch_top_level_json "$input_url" "$top_level_json" "$top_level_error" top_level_used_cookies; then
    if is_age_gate_error "$top_level_error"; then
      if is_cookie_decryption_error "$top_level_error"; then
        die "${COOKIE_BROWSER} cookies could not be decrypted. Unlock your desktop keyring, re-open the browser, or try YTB_COOKIES_BROWSER=firefox."
      elif ((COOKIE_BROWSER_AVAILABLE)); then
        die "A signed-in ${COOKIE_BROWSER} profile is required for this age-restricted video."
      fi
      die "This URL requires a signed-in browser profile. Set YTB_COOKIES_BROWSER to a browser that is signed in."
    fi
    die "Failed to inspect the YouTube URL"
  fi

  if is_playlist_json "$top_level_json"; then
    if process_playlist "$top_level_json"; then
      rm -f "$top_level_json" "$top_level_error"
      exit 0
    fi
    rm -f "$top_level_json" "$top_level_error"
    exit 1
  fi

  if process_video "$input_url" "$OUTPUT_ROOT" "Video" ""; then
    rm -f "$top_level_json" "$top_level_error"
    exit 0
  fi

  rm -f "$top_level_json" "$top_level_error"
  exit 1
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  main "$@"
fi
