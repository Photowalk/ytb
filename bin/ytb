#!/usr/bin/env bash

set -uo pipefail
shopt -s nullglob

SCRIPT_NAME="ytb"
OUTPUT_ROOT="${YTB_OUTPUT_ROOT:-${HOME}/Videos}"
COOKIE_BROWSER="${YTB_COOKIES_BROWSER:-chrome}"
AUTO_UPDATE_DAYS="${YTB_AUTO_UPDATE_DAYS:-7}"
VIDEO_ENCODER_MODE="${YTB_VIDEO_ENCODER:-auto}"
STATE_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/ytb"
LOCAL_BIN_DIR="${HOME}/.local/bin"

CURRENT_LOG_FILE=""
LAST_VIDEO_STATUS="failed"
COOKIE_BROWSER_AVAILABLE=0
YTDLP_BIN=""
SELECTED_VIDEO_ENCODER="libx264"

usage() {
  cat <<'EOF'
Usage: ytb <youtube-url>

Downloads a YouTube video or playlist into ~/Videos by default.
- Each video gets its own directory.
- Manual English subtitles are burned into a final MP4 when available.
- Auto-generated subtitles are never used.
- yt-dlp is auto-installed from the official upstream release and refreshed periodically.
- Age-restricted videos retry with browser cookies only when needed.

Optional environment variables:
- YTB_OUTPUT_ROOT=/path/to/output
- YTB_COOKIES_BROWSER=chrome|firefox|chromium|none
- YTB_AUTO_UPDATE_DAYS=7
- YTB_VIDEO_ENCODER=auto|cpu|libx264|h264_nvenc|hevc_nvenc|av1_nvenc
EOF
}

log() {
  local message="$1"
  printf '[%s] %s\n' "$SCRIPT_NAME" "$message" >&2
  if [[ -n "${CURRENT_LOG_FILE:-}" ]]; then
    printf '[%s] %s\n' "$SCRIPT_NAME" "$message" >>"$CURRENT_LOG_FILE"
  fi
}

warn() {
  log "WARNING: $1"
}

die() {
  log "ERROR: $1"
  exit 1
}

run_logged() {
  local log_file="${CURRENT_LOG_FILE:-}"
  if [[ -n "$log_file" ]]; then
    "$@" 2>&1 | tee -a "$log_file"
    return "${PIPESTATUS[0]}"
  fi
  "$@"
}

sanitize_name() {
  local input="$1"
  local sanitized

  sanitized="$(printf '%s' "$input" \
    | tr '\r\n\t' '   ' \
    | sed -E "s/[^[:alnum:] ._()-]+/-/g; s/[[:space:]]+/ /g; s/^[[:space:].-]+//; s/[[:space:].-]+$//; s/-{2,}/-/g" \
    | cut -c1-180)"

  if [[ -z "$sanitized" ]]; then
    sanitized="untitled"
  fi

  printf '%s' "$sanitized"
}

get_url_host() {
  local url="$1"
  local without_scheme="${url#*://}"
  printf '%s' "${without_scheme%%/*}"
}

is_supported_youtube_url() {
  local url="$1"
  local host

  [[ "$url" == http://* || "$url" == https://* ]] || return 1
  host="$(get_url_host "$url")"

  case "$host" in
    youtube.com|www.youtube.com|m.youtube.com|youtu.be)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

ensure_base_dependencies() {
  local missing=()
  local dep

  for dep in curl jq ffmpeg; do
    if ! command -v "$dep" >/dev/null 2>&1; then
      missing+=("$dep")
    fi
  done

  if ((${#missing[@]} == 0)); then
    return 0
  fi

  log "Installing missing Ubuntu packages: ${missing[*]}"

  if ! command -v sudo >/dev/null 2>&1; then
    die "sudo is required to install missing dependencies automatically"
  fi

  if ! sudo apt-get update; then
    die "Failed to run: sudo apt-get update"
  fi

  if ! sudo apt-get install -y "${missing[@]}"; then
    die "Failed to install required Ubuntu packages"
  fi

  for dep in curl jq ffmpeg; do
    command -v "$dep" >/dev/null 2>&1 || die "$dep is still unavailable after installation"
  done
}

detect_ytdlp_asset() {
  case "$(uname -m)" in
    x86_64|amd64)
      printf 'yt-dlp_linux'
      ;;
    aarch64|arm64)
      printf 'yt-dlp_linux_aarch64'
      ;;
    *)
      printf 'yt-dlp'
      ;;
  esac
}

refresh_is_due() {
  local stamp_file="$1"
  local max_age_days="$2"
  local now last_check

  [[ -f "$stamp_file" ]] || return 0
  now="$(date +%s)"
  last_check="$(cat "$stamp_file" 2>/dev/null || printf '0')"

  [[ "$last_check" =~ ^[0-9]+$ ]] || return 0
  (( now - last_check >= max_age_days * 86400 ))
}

mark_refreshed() {
  local stamp_file="$1"
  mkdir -p "$(dirname "$stamp_file")"
  date +%s >"$stamp_file"
}

install_latest_ytdlp() {
  local target_path="${LOCAL_BIN_DIR}/yt-dlp"
  local temp_file asset_name url version

  mkdir -p "$LOCAL_BIN_DIR"
  asset_name="$(detect_ytdlp_asset)"
  url="https://github.com/yt-dlp/yt-dlp/releases/latest/download/${asset_name}"
  temp_file="$(mktemp)"

  log "Installing latest yt-dlp from official release"
  if ! curl -fsSL "$url" -o "$temp_file"; then
    rm -f "$temp_file"
    return 1
  fi

  if ! install -m 0755 "$temp_file" "$target_path"; then
    rm -f "$temp_file"
    return 1
  fi
  rm -f "$temp_file"

  YTDLP_BIN="$target_path"
  version="$("$YTDLP_BIN" --version 2>/dev/null | head -n 1 || true)"
  [[ -n "$version" ]] || return 1
  log "Using yt-dlp ${version} from ${YTDLP_BIN}"
  return 0
}

ensure_ytdlp() {
  local refresh_stamp="${STATE_DIR}/yt-dlp-last-refresh"
  local system_ytdlp
  local refresh_due=0

  if [[ -x "${LOCAL_BIN_DIR}/yt-dlp" ]]; then
    YTDLP_BIN="${LOCAL_BIN_DIR}/yt-dlp"
  else
    system_ytdlp="$(command -v yt-dlp 2>/dev/null || true)"
    if [[ -n "$system_ytdlp" ]]; then
      YTDLP_BIN="$system_ytdlp"
    fi
  fi

  if refresh_is_due "$refresh_stamp" "$AUTO_UPDATE_DAYS"; then
    refresh_due=1
  fi

  if [[ -z "$YTDLP_BIN" || ! -x "$YTDLP_BIN" ]] || ((refresh_due)); then
    if ! install_latest_ytdlp; then
      if [[ -n "$YTDLP_BIN" && -x "$YTDLP_BIN" ]]; then
        warn "Could not refresh yt-dlp from GitHub; falling back to ${YTDLP_BIN}"
      else
        die "Could not install yt-dlp from GitHub"
      fi
    else
      mark_refreshed "$refresh_stamp"
    fi
  fi

  [[ -n "$YTDLP_BIN" && -x "$YTDLP_BIN" ]] || die "yt-dlp is unavailable after installation"
}

browser_profile_exists() {
  local browser="$1"

  case "$browser" in
    none)
      return 1
      ;;
    chrome)
      [[ -d "${HOME}/.config/google-chrome" \
        || -d "${HOME}/.config/google-chrome-beta" \
        || -d "${HOME}/.config/google-chrome-unstable" ]]
      ;;
    firefox)
      [[ -d "${HOME}/.mozilla/firefox" ]]
      ;;
    chromium)
      [[ -d "${HOME}/.config/chromium" ]]
      ;;
    *)
      return 0
      ;;
  esac
}

init_cookie_support() {
  if [[ "$COOKIE_BROWSER" == "none" ]]; then
    COOKIE_BROWSER_AVAILABLE=0
    log "Browser cookies disabled via YTB_COOKIES_BROWSER=none"
    return 0
  fi

  if browser_profile_exists "$COOKIE_BROWSER"; then
    COOKIE_BROWSER_AVAILABLE=1
    log "Will retry age-restricted videos with browser cookies from ${COOKIE_BROWSER}"
    return 0
  fi

  COOKIE_BROWSER_AVAILABLE=0
  warn "No usable ${COOKIE_BROWSER} browser profile was found. Public videos can still work, but age-restricted videos may fail."
}

ffmpeg_has_encoder() {
  local encoder="$1"
  grep -Eq "[[:space:]]${encoder}[[:space:]]" < <(ffmpeg -hide_banner -encoders 2>/dev/null)
}

init_video_encoder() {
  case "$VIDEO_ENCODER_MODE" in
    auto)
      if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder h264_nvenc; then
        SELECTED_VIDEO_ENCODER="h264_nvenc"
        log "Using NVIDIA GPU video encoding via h264_nvenc"
      else
        SELECTED_VIDEO_ENCODER="libx264"
        log "Using CPU video encoding via libx264"
      fi
      ;;
    cpu|libx264)
      SELECTED_VIDEO_ENCODER="libx264"
      log "Using CPU video encoding via libx264"
      ;;
    h264_nvenc|hevc_nvenc|av1_nvenc)
      if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder "$VIDEO_ENCODER_MODE"; then
        SELECTED_VIDEO_ENCODER="$VIDEO_ENCODER_MODE"
        log "Using NVIDIA GPU video encoding via ${SELECTED_VIDEO_ENCODER}"
      else
        warn "Requested ${VIDEO_ENCODER_MODE}, but it is not available. Falling back to CPU libx264."
        SELECTED_VIDEO_ENCODER="libx264"
      fi
      ;;
    *)
      warn "Unknown YTB_VIDEO_ENCODER=${VIDEO_ENCODER_MODE}. Falling back to auto detection."
      if command -v nvidia-smi >/dev/null 2>&1 && ffmpeg_has_encoder h264_nvenc; then
        SELECTED_VIDEO_ENCODER="h264_nvenc"
        log "Using NVIDIA GPU video encoding via h264_nvenc"
      else
        SELECTED_VIDEO_ENCODER="libx264"
        log "Using CPU video encoding via libx264"
      fi
      ;;
  esac
}

is_age_gate_error() {
  local error_file="$1"
  grep -Eiq 'Sign in to confirm your age|Please sign in|This video may be inappropriate for some users|age-restricted' "$error_file"
}

is_cookie_decryption_error() {
  local error_file="$1"
  grep -Eiq 'cannot decrypt|could not decrypt|could not be decrypted|Extracted 0 cookies|no key found' "$error_file"
}

yt_dlp_capture_json() {
  local output_json="$1"
  local error_file="$2"
  local cookie_mode_var="$3"
  shift 3
  local -a args=("$@")

  if "$YTDLP_BIN" "${args[@]}" >"$output_json" 2>"$error_file"; then
    printf -v "$cookie_mode_var" '%s' "0"
    return 0
  fi

  if ((COOKIE_BROWSER_AVAILABLE)) && is_age_gate_error "$error_file"; then
    log "Retrying with ${COOKIE_BROWSER} cookies"
    if "$YTDLP_BIN" --cookies-from-browser "$COOKIE_BROWSER" "${args[@]}" >"$output_json" 2>"$error_file"; then
      printf -v "$cookie_mode_var" '%s' "1"
      return 0
    fi
  fi

  printf -v "$cookie_mode_var" '%s' "0"
  return 1
}

choose_manual_english_subtitle() {
  local metadata_json="$1"

  jq -r '
    (.subtitles // {}) as $subs
    | if ($subs | has("en")) then
        "en"
      elif ($subs | has("en-US")) then
        "en-US"
      elif ($subs | has("en-GB")) then
        "en-GB"
      else
        ($subs | keys_unsorted[]? | select(test("^en-")))
      end
  ' "$metadata_json" | head -n 1
}

is_playlist_json() {
  local metadata_json="$1"

  jq -e '
    (._type // "") == "playlist"
    or ((.entries // null) != null and (.entries | type) == "array")
  ' "$metadata_json" >/dev/null 2>&1
}

build_watch_url() {
  local value="$1"
  printf 'https://www.youtube.com/watch?v=%s' "$value"
}

write_error_log() {
  local error_file="$1"
  if [[ -n "${CURRENT_LOG_FILE:-}" && -f "$error_file" ]]; then
    cat "$error_file" >>"$CURRENT_LOG_FILE"
  fi
}

fetch_top_level_json() {
  local url="$1"
  local output_json="$2"
  local error_file="$3"
  local cookie_mode_var="$4"

  yt_dlp_capture_json "$output_json" "$error_file" "$cookie_mode_var" \
    --dump-single-json \
    --flat-playlist \
    "$url"
}

fetch_video_metadata() {
  local url="$1"
  local output_json="$2"
  local error_file="$3"
  local cookie_mode_var="$4"

  yt_dlp_capture_json "$output_json" "$error_file" "$cookie_mode_var" \
    --dump-single-json \
    "$url"
}

download_media() {
  local url="$1"
  local outtmpl="$2"
  local path_file="$3"
  local use_cookies="$4"
  local -a cookie_args=()

  if [[ "$use_cookies" == "1" ]]; then
    cookie_args=(--cookies-from-browser "$COOKIE_BROWSER")
  fi

  : >"$path_file"
  run_logged "$YTDLP_BIN" \
    "${cookie_args[@]}" \
    --print-to-file after_move:filepath "$path_file" \
    --format "bv*+ba/b" \
    --output "$outtmpl" \
    "$url"
}

download_manual_subtitles() {
  local url="$1"
  local outtmpl="$2"
  local subtitle_lang="$3"
  local use_cookies="$4"
  local -a cookie_args=()

  if [[ "$use_cookies" == "1" ]]; then
    cookie_args=(--cookies-from-browser "$COOKIE_BROWSER")
  fi

  run_logged "$YTDLP_BIN" \
    "${cookie_args[@]}" \
    --skip-download \
    --write-subs \
    --sub-langs "$subtitle_lang" \
    --convert-subs srt \
    --output "$outtmpl" \
    "$url"
}

burn_subtitles() {
  local media_path="$1"
  local subtitle_path="$2"
  local output_path="$3"
  local workdir media_name output_name temp_subtitle temp_subtitle_name
  local encoder="${SELECTED_VIDEO_ENCODER}"
  local status

  workdir="$(dirname "$subtitle_path")"
  media_name="$(basename "$media_path")"
  output_name="$(basename "$output_path")"
  temp_subtitle_name=".ytb-burn-input.srt"
  temp_subtitle="${workdir}/${temp_subtitle_name}"

  cp "$subtitle_path" "$temp_subtitle" || return 1

  (
    local -a video_args
    cd "$workdir" || exit 1

    case "$encoder" in
      h264_nvenc)
        video_args=(-c:v h264_nvenc -preset p5 -rc:v vbr -cq:v 19 -b:v 0 -pix_fmt yuv420p)
        ;;
      hevc_nvenc)
        video_args=(-c:v hevc_nvenc -preset p5 -rc:v vbr -cq:v 21 -b:v 0 -pix_fmt yuv420p)
        ;;
      av1_nvenc)
        video_args=(-c:v av1_nvenc -preset p5 -cq:v 28 -b:v 0 -pix_fmt yuv420p)
        ;;
      *)
        video_args=(-c:v libx264 -preset medium -crf 18 -pix_fmt yuv420p)
        ;;
    esac

    run_logged ffmpeg \
      -y \
      -i "$media_name" \
      -vf "subtitles=${temp_subtitle_name}" \
      -map "0:v:0" \
      -map "0:a?" \
      "${video_args[@]}" \
      -c:a aac \
      -b:a 192k \
      -movflags +faststart \
      -sn \
      "$output_name"
  )
  status=$?

  if [[ "$status" -ne 0 && "$encoder" != "libx264" ]]; then
    warn "GPU encode with ${encoder} failed. Retrying with CPU libx264."
    rm -f "$temp_subtitle"
    cp "$subtitle_path" "$temp_subtitle" || return 1
    (
      cd "$workdir" || exit 1
      run_logged ffmpeg \
        -y \
        -i "$media_name" \
        -vf "subtitles=${temp_subtitle_name}" \
        -map "0:v:0" \
        -map "0:a?" \
        -c:v libx264 \
        -preset medium \
        -crf 18 \
        -pix_fmt yuv420p \
        -c:a aac \
        -b:a 192k \
        -movflags +faststart \
        -sn \
        "$output_name"
    )
    status=$?
  fi

  rm -f "$temp_subtitle"
  return "$status"
}

record_metadata_copy() {
  local source_json="$1"
  local target_path="$2"
  cp "$source_json" "$target_path"
}

process_video() {
  local video_url="$1"
  local parent_dir="$2"
  local fallback_title="${3:-Unknown Video}"
  local fallback_id="${4:-}"

  local metadata_json error_file used_cookies
  local raw_title safe_title video_id dir_name video_dir
  local base_name base_path subtitle_lang subtitle_path burned_path
  local path_file media_path

  LAST_VIDEO_STATUS="failed"
  metadata_json="$(mktemp)"
  error_file="$(mktemp)"
  used_cookies="0"

  if ! fetch_video_metadata "$video_url" "$metadata_json" "$error_file" used_cookies; then
    safe_title="$(sanitize_name "$fallback_title")"
    if [[ -n "$fallback_id" ]]; then
      dir_name="${safe_title} [${fallback_id}]"
    else
      dir_name="$safe_title"
    fi
    video_dir="${parent_dir}/${dir_name}"
    mkdir -p "$video_dir"
    CURRENT_LOG_FILE="${video_dir}/ytb.log"
    : >"$CURRENT_LOG_FILE"
    write_error_log "$error_file"

    if is_age_gate_error "$error_file"; then
      if is_cookie_decryption_error "$error_file"; then
        warn "Failed to access ${video_url}. ${COOKIE_BROWSER} cookies could not be decrypted. Unlock your desktop keyring, re-open the browser, or try YTB_COOKIES_BROWSER=firefox."
      elif ((COOKIE_BROWSER_AVAILABLE)); then
        warn "Failed to access ${video_url}. A signed-in ${COOKIE_BROWSER} profile is required for this age-restricted video."
      else
        warn "Failed to access ${video_url}. Configure YTB_COOKIES_BROWSER for a signed-in browser profile to handle age-restricted videos."
      fi
    else
      warn "Failed to fetch metadata for ${video_url}"
    fi

    rm -f "$metadata_json" "$error_file"
    return 1
  fi

  raw_title="$(jq -r '.title // empty' "$metadata_json")"
  video_id="$(jq -r '.id // empty' "$metadata_json")"
  if [[ -z "$raw_title" ]]; then
    raw_title="$fallback_title"
  fi
  if [[ -z "$video_id" ]]; then
    video_id="$fallback_id"
  fi

  safe_title="$(sanitize_name "$raw_title")"
  if [[ -n "$video_id" ]]; then
    dir_name="${safe_title} [${video_id}]"
  else
    dir_name="$safe_title"
  fi

  video_dir="${parent_dir}/${dir_name}"
  mkdir -p "$video_dir"
  CURRENT_LOG_FILE="${video_dir}/ytb.log"
  : >"$CURRENT_LOG_FILE"

  record_metadata_copy "$metadata_json" "${video_dir}/metadata.json"
  log "Processing video: ${raw_title}"

  base_name="$dir_name"
  base_path="${video_dir}/${base_name}"
  path_file="$(mktemp)"

  if ! download_media "$video_url" "${base_path}.%(ext)s" "$path_file" "$used_cookies"; then
    warn "Media download failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  media_path="$(tail -n 1 "$path_file")"
  if [[ -z "$media_path" || ! -f "$media_path" ]]; then
    warn "Could not determine downloaded media path for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  subtitle_lang="$(choose_manual_english_subtitle "$metadata_json")"
  if [[ -z "$subtitle_lang" ]]; then
    warn "No manual English subtitles found for ${raw_title}; kept media without burned subtitles"
    LAST_VIDEO_STATUS="downloaded_no_subtitles"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 0
  fi

  if ! download_manual_subtitles "$video_url" "${base_path}.%(ext)s" "$subtitle_lang" "$used_cookies"; then
    warn "Subtitle download failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  subtitle_path="${base_path}.${subtitle_lang}.srt"
  if [[ ! -f "$subtitle_path" ]]; then
    local matches=( "${base_path}".en*.srt )
    if ((${#matches[@]} > 0)); then
      subtitle_path="${matches[0]}"
    fi
  fi

  if [[ ! -f "$subtitle_path" ]]; then
    warn "Subtitle file was not created for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  burned_path="${base_path} [burned].mp4"
  if ! burn_subtitles "$media_path" "$subtitle_path" "$burned_path"; then
    warn "Subtitle burn-in failed for ${raw_title}"
    rm -f "$metadata_json" "$error_file" "$path_file"
    return 1
  fi

  log "Created burned video: ${burned_path}"
  LAST_VIDEO_STATUS="burned"
  rm -f "$metadata_json" "$error_file" "$path_file"
  return 0
}

process_playlist() {
  local top_level_json="$1"

  local playlist_title playlist_id safe_playlist_title playlist_dir
  local -a entry_payloads failed_items
  local processed=0 burned=0 without_subtitles=0 hard_failures=0
  local entry_payload entry_json fallback_id fallback_title entry_url

  playlist_title="$(jq -r '.title // .playlist_title // "Playlist"' "$top_level_json")"
  playlist_id="$(jq -r '.id // .playlist_id // empty' "$top_level_json")"
  safe_playlist_title="$(sanitize_name "$playlist_title")"

  if [[ -n "$playlist_id" ]]; then
    playlist_dir="${OUTPUT_ROOT}/${safe_playlist_title} [${playlist_id}]"
  else
    playlist_dir="${OUTPUT_ROOT}/${safe_playlist_title}"
  fi

  mkdir -p "$playlist_dir"
  record_metadata_copy "$top_level_json" "${playlist_dir}/metadata.json"
  CURRENT_LOG_FILE="${playlist_dir}/ytb.log"
  : >"$CURRENT_LOG_FILE"
  log "Processing playlist: ${playlist_title}"

  mapfile -t entry_payloads < <(jq -r '(.entries // [])[] | @base64' "$top_level_json")
  if ((${#entry_payloads[@]} == 0)); then
    die "Playlist metadata was fetched, but no entries were found"
  fi

  for entry_payload in "${entry_payloads[@]}"; do
    processed=$((processed + 1))
    entry_json="$(printf '%s' "$entry_payload" | base64 --decode)"
    fallback_id="$(jq -r '.id // empty' <<<"$entry_json")"
    fallback_title="$(jq -r '.title // "Unknown Video"' <<<"$entry_json")"
    entry_url="$(jq -r '.webpage_url // .url // empty' <<<"$entry_json")"

    if [[ -z "$entry_url" && -n "$fallback_id" ]]; then
      entry_url="$(build_watch_url "$fallback_id")"
    elif [[ -n "$entry_url" && "$entry_url" != http://* && "$entry_url" != https://* ]]; then
      entry_url="$(build_watch_url "$entry_url")"
    fi

    if [[ -z "$entry_url" ]]; then
      hard_failures=$((hard_failures + 1))
      failed_items+=("${fallback_title}${fallback_id:+ [${fallback_id}]}")
      warn "Skipping a playlist entry because no usable video URL was present"
      continue
    fi

    if process_video "$entry_url" "$playlist_dir" "$fallback_title" "$fallback_id"; then
      case "$LAST_VIDEO_STATUS" in
        burned)
          burned=$((burned + 1))
          ;;
        downloaded_no_subtitles)
          without_subtitles=$((without_subtitles + 1))
          ;;
      esac
    else
      hard_failures=$((hard_failures + 1))
      failed_items+=("${fallback_title}${fallback_id:+ [${fallback_id}]}")
    fi
  done

  CURRENT_LOG_FILE="${playlist_dir}/ytb.log"
  log "Playlist summary: total=${processed}, burned=${burned}, no-manual-en-subs=${without_subtitles}, hard-failures=${hard_failures}"

  if ((${#failed_items[@]} > 0)); then
    printf '[%s] Failed items:\n' "$SCRIPT_NAME" >&2
    for entry_payload in "${failed_items[@]}"; do
      printf '[%s] - %s\n' "$SCRIPT_NAME" "$entry_payload" >&2
      printf '[%s] - %s\n' "$SCRIPT_NAME" "$entry_payload" >>"$CURRENT_LOG_FILE"
    done
  fi

  if ((hard_failures > 0)); then
    return 1
  fi
  return 0
}

main() {
  local input_url top_level_json top_level_error top_level_used_cookies

  if [[ $# -ne 1 ]]; then
    usage >&2
    exit 1
  fi

  input_url="$1"
  if ! is_supported_youtube_url "$input_url"; then
    die "Unsupported URL. Pass a YouTube watch, short, shorts, or playlist URL."
  fi

  ensure_base_dependencies
  ensure_ytdlp
  init_cookie_support
  init_video_encoder
  mkdir -p "$OUTPUT_ROOT"

  top_level_json="$(mktemp)"
  top_level_error="$(mktemp)"
  top_level_used_cookies="0"

  if ! fetch_top_level_json "$input_url" "$top_level_json" "$top_level_error" top_level_used_cookies; then
    if is_age_gate_error "$top_level_error"; then
      if is_cookie_decryption_error "$top_level_error"; then
        die "${COOKIE_BROWSER} cookies could not be decrypted. Unlock your desktop keyring, re-open the browser, or try YTB_COOKIES_BROWSER=firefox."
      elif ((COOKIE_BROWSER_AVAILABLE)); then
        die "A signed-in ${COOKIE_BROWSER} profile is required for this age-restricted video."
      fi
      die "This URL requires a signed-in browser profile. Set YTB_COOKIES_BROWSER to a browser that is signed in."
    fi
    die "Failed to inspect the YouTube URL"
  fi

  if is_playlist_json "$top_level_json"; then
    if process_playlist "$top_level_json"; then
      rm -f "$top_level_json" "$top_level_error"
      exit 0
    fi
    rm -f "$top_level_json" "$top_level_error"
    exit 1
  fi

  if process_video "$input_url" "$OUTPUT_ROOT" "Video" ""; then
    rm -f "$top_level_json" "$top_level_error"
    exit 0
  fi

  rm -f "$top_level_json" "$top_level_error"
  exit 1
}

main "$@"
